# Copy this file to .env and fill in real values. .env is gitignored.
#
# Loaded automatically by both entry points (src/main.ts, src/cli.ts) via
# `dotenv`. The CLI takes no provider flags at all — every value here is the
# only place provider selection/tuning comes from for a CLI run. The HTTP API
# still accepts optional per-request overrides for some of these (see the
# README's API section).

# HTTP API port (src/main.ts). Not used by the CLI.
PORT=3000

# Which provider `EnrichmentService` uses when a caller doesn't pick one
# explicitly (the CLI never does). One of the `ProviderType` values in
# src/providers/enrichment-provider.types.ts.
DEFAULT_ENRICHMENT_PROVIDER=mock

# --- mock provider (src/providers/mock) -------------------------------------
# See src/providers/enrichment-provider-manager.service.ts for how these are
# read and defaulted.
MOCK_PROVIDER_URL=http://localhost:4000
MOCK_PROVIDER_API_KEY=demo-token
MOCK_PROVIDER_MAX_RETRIES=5
MOCK_PROVIDER_BATCH_SIZE=10
MOCK_PROVIDER_CONCURRENCY=4
MOCK_PROVIDER_TIMEOUT_MS=10000

# --- outcome storage (src/outcome-store) ------------------------------------
# Where a run holds resolved outcomes while it's in progress. See
# src/outcome-store/outcome-store.factory.ts.
#   memory (default) - a plain Map. Measured at ~120MB RSS for a synthetic
#                       100k-domain run (input rows + dedup set + fully
#                       enriched outcomes, all resident at once) - fine for
#                       any realistic deployment target.
#   file            - spills outcomes to a local NDJSON file, keeping only a
#                       byte-offset index in memory. Use if that ~120MB isn't
#                       acceptable for your environment.
ENRICHMENT_OUTCOME_STORE=memory

# Directory FileOutcomeStore writes its temp file into (only used when
# ENRICHMENT_OUTCOME_STORE=file). Defaults to the OS temp directory.
# ENRICHMENT_OUTCOME_STORE_DIR=/tmp
